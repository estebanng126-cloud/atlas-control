# Copy to .env in this folder or export before `pnpm dev` for @atlas/api.
# Never commit real keys.

# --- Local LLM (LM Studio, OpenAI-compatible) — used when LOCAL_AI_BASE_URL is set ---
# LOCAL_AI_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_AI_MODEL=<id from GET /v1/models, e.g. loaded model name>
# Optional if you enabled server auth in LM Studio Developer settings:
# LOCAL_AI_API_KEY=

# --- Cloud OpenAI — used only when LOCAL_AI_BASE_URL is unset ---
OPENAI_API_KEY=

# Optional; default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
